#!/usr/bin/env bash
set -euo pipefail

expected_name="Ren"
expected_email="rpdeshaies+rendotdev@gmail.com"

config_name="$(git config --get user.name || true)"
config_email="$(git config --get user.email || true)"
author_ident="$(git var GIT_AUTHOR_IDENT)"
committer_ident="$(git var GIT_COMMITTER_IDENT)"

if [[ "$config_name" != "$expected_name" || "$config_email" != "$expected_email" ]]; then
  cat >&2 <<MSG
This repo must commit as the rendotdev identity.
Expected: $expected_name <$expected_email>
Actual:   $config_name <$config_email>

Run:
  git config user.name "$expected_name"
  git config user.email "$expected_email"
MSG
  exit 1
fi

if [[ "$author_ident" != *"<$expected_email>"* || "$committer_ident" != *"<$expected_email>"* ]]; then
  cat >&2 <<MSG
Commit author and committer must use the rendotdev email.
Expected email: $expected_email
Author:    $author_ident
Committer: $committer_ident
MSG
  exit 1
fi
