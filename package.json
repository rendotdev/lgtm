{
  "name": "@rendotdev/lgtm",
  "version": "0.1.0",
  "private": false,
  "description": "Human approval for agent work, with code diff and Markdown review.",
  "keywords": [
    "ai-agents",
    "bun",
    "code-review",
    "human-in-the-loop",
    "rendotdev"
  ],
  "homepage": "https://github.com/rendotdev/lgtm#readme",
  "bugs": {
    "url": "https://github.com/rendotdev/lgtm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rendotdev/lgtm.git"
  },
  "bin": {
    "lgtm": "dist/cli.mjs"
  },
  "files": [
    "README.md",
    "extensions/lgtm.ts",
    "dist",
    "src",
    "tsconfig.json"
  ],
  "type": "module",
  "scripts": {
    "lgtm": "bun src/cli.ts",
    "pack:dry": "bun pm pack --dry-run"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@types/bun": "^1.2.0",
    "@types/node": "^24.0.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.14",
  "pi": {
    "extensions": [
      "extensions/lgtm.ts"
    ]
  }
}
